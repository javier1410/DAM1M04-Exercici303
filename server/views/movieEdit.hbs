{{> header}}
{{> menu}}

<h2>Editar pel·lícula</h2>

<form method="POST" action="/editarPeli" class="formulari">
  
  <input type="hidden" name="film_id" value="{{movie.film_id}}">

  <label for="title">Títol:</label>
  <input id="title" type="text" name="title" value="{{movie.title}}" required>

  <label for="description">Descripció:</label>
  <input id="description" type="text" name="description" value="{{movie.description}}">

  <label for="release_year">Any de publicació:</label>
  <input id="release_year" type="number" name="release_year" value="{{movie.release_year}}">

  <label for="language_id">Idioma (ID):</label>
  <input id="language_id" type="number" name="language_id" value="{{movie.language_id}}" required>

  <button type="submit">Guardar canvis</button>
</form>

<form method="POST" action="/esborrarPeli">
  <input type="hidden" name="film_id" value="{{movie.film_id}}">
  <button type="submit">Esborrar pel·lícula</button>
</form>

{{> footer}}